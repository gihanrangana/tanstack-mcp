{
	"name": "@gihan.rangana/tanstack-mcp",

	"version": "1.0.0",
	"description": "MCP server providing TanStack library documentation and tools",
	"type": "module",
	"types": "./types.d.ts",
	"main": "./dist/index.mjs",
	"bin": {
		"tanstack-mcp": "./dist/index.mjs"
	},
	"files": [
		"dist",
		"types.d.ts",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsx --watch src/index.ts",
		"dev:inspect": "npx -y @modelcontextprotocol/inspector tsx src/index.ts",
		"start": "node dist/index.mjs",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"mcp",
		"tanstack",
		"documentation",
		"ai",
		"tools"
	],
	"author": "Gihan Rangana<itsmerangana@gmail.com>",
	"license": "MIT",

	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^22.0.0",
		"tsdown": "^0.21.4",
		"tsx": "^4.21.0",
		"typescript": "^5.8.0"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
